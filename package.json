{
	"name": "twillm",
	"version": "0.0.1",
	"description": "TiddlyWiki-based LLM knowledge wiki",
	"scripts": {
		"start": "tiddlywiki wiki --listen",
		"build": "tiddlywiki wiki --render '[type[text/x-markdown]]' '[encodeuricomponent[]addsuffix[.html]]' text/plain '$:/core/templates/static.tiddler.html'"
	},
	"dependencies": {
		"tiddlywiki": "github:TiddlyWiki/TiddlyWiki5#bidirectional-filesystem"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Jermolene/twillm.git"
	},
	"author": "Jeremy Ruston",
	"license": "BSD-3-Clause"
}
