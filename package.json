{
	"name": "twillm",
	"version": "0.0.1",
	"description": "TiddlyWiki served live over your Markdown vault — drop-in viewer for LLM-authored knowledge bases",
	"keywords": [
		"tiddlywiki",
		"obsidian",
		"llm",
		"vault",
		"knowledge-base",
		"markdown",
		"karpathy"
	],
	"homepage": "https://github.com/Jermolene/twillm",
	"bugs": {
		"url": "https://github.com/Jermolene/twillm/issues"
	},
	"bin": {
		"twillm": "./cli.js"
	},
	"files": [
		"cli.js",
		"template-wiki/",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"start": "node ./cli.js vault",
		"build": "node ./cli.js vault -- --render '[type[text/x-markdown]]' '[encodeuricomponent[]addsuffix[.html]]' text/plain '$:/core/templates/static.tiddler.html'"
	},
	"dependencies": {
		"tiddlywiki": "github:TiddlyWiki/TiddlyWiki5#bidirectional-filesystem",
		"tw5-graph": "github:flibbles/tw5-graph",
		"tw5-vis-network": "github:flibbles/tw5-vis-network#v10.5.5"
	},
	"engines": {
		"node": ">=22"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Jermolene/twillm.git"
	},
	"author": "Jeremy Ruston",
	"license": "BSD-3-Clause"
}
