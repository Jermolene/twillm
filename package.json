{
	"name": "twillm",
	"version": "0.0.1",
	"description": "TiddlyWiki-based LLM knowledge wiki",
	"scripts": {
		"test": "node tiddlywiki-wrapper/tests/yaml.test.js",
		"start": "node tiddlywiki-wrapper/start.js wiki --load sample-vault --mcp readwrite listen",
		"build": "node tiddlywiki-wrapper/start.js wiki --load sample-vault --render '[type[text/x-markdown]]' '[encodeuricomponent[]addsuffix[.html]]' text/plain '$:/core/templates/static.tiddler.html'"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Jermolene/twillm.git"
	},
	"author": "Jeremy Ruston",
	"license": "BSD-3-Clause"
}
